generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(uuid())
  firebaseId   String         @unique
  email        String         @unique
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  groups       GroupMember[]
  Meeting      Meeting[]
  Notification Notification[]
}

model Group {
  id                 String         @id @default(uuid())
  name               String
  inviteCode         String         @unique
  inviteCodeExpiry   DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  contributionAmount Float?
  payoutOrder        String?
  meetingFrequency   String?
  contributions      Contribution[]
  members            GroupMember[]
  Meeting            Meeting[]
}

model GroupMember {
  id                     String         @id @default(uuid())
  userId                 String
  groupId                String
  role                   Role           @default(MEMBER)
  joinedAt               DateTime       @default(now())
  confirmedContributions Contribution[] @relation("TreasurerConfirmations")
  contributions          Contribution[] @relation("MemberContributions")
  group                  Group          @relation(fields: [groupId], references: [id])
  user                   User           @relation(fields: [userId], references: [id])

  @@unique([userId, groupId])
}

model Contribution {
  id          String             @id @default(uuid())
  amount      Float
  date        DateTime
  status      ContributionStatus @default(PENDING)
  memberId    String
  groupId     String
  confirmedBy String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  treasurer   GroupMember?       @relation("TreasurerConfirmations", fields: [confirmedBy], references: [id])
  group       Group              @relation(fields: [groupId], references: [id])
  member      GroupMember        @relation("MemberContributions", fields: [memberId], references: [id])
}

model Meeting {
  id           String         @id
  groupId      String
  date         DateTime
  location     String
  agenda       String?
  minutes      String?
  createdAt    DateTime       @default(now())
  createdById  String
  User         User           @relation(fields: [createdById], references: [id])
  Group        Group          @relation(fields: [groupId], references: [id])
  Notification Notification[]
}

model Notification {
  id          String           @id
  type        NotificationType
  recipientId String
  meetingId   String
  sentAt      DateTime         @default(now())
  success     Boolean          @default(true)
  error       String?
  Meeting     Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  User        User             @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([recipientId])
  @@index([type])
}

enum Role {
  MEMBER
  TREASURER
  ADMIN
}

enum ContributionStatus {
  CONFIRMED
  MISSED
  PENDING
}

enum NotificationType {
  MEETING_CREATED
  MEETING_UPDATED
  MEETING_DELETED
}
